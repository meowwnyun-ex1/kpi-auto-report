{
  "name": "kpi-auto-report",
  "version": "1.0.0",
  "description": "KPI Management Tool System for DENSO",
  "scripts": {
    "dev": "concurrently \"pnpm dev:api\" \"pnpm dev:frontend\"",
    "dev:api": "cross-env NODE_ENV=development nodemon server/api.ts",
    "dev:frontend": "vite",
    "build:server": "pnpm exec tsc -p server/tsconfig.json",
    "build:frontend": "vite build",
    "build": "pnpm run build:server && pnpm run build:frontend",
    "preview": "vite preview",
    "start": "cross-env NODE_ENV=production node server/dist/api.js",
    "start:prod": "cross-env NODE_ENV=production node server/dist/api.js",
    "preview:prod": "cross-env NODE_ENV=production vite preview --port 3007",
    "deploy": "deploy.ps1",
    "pm2:start": "cross-env NODE_ENV=production pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop kpi-auto-report-api",
    "pm2:restart": "pm2 restart kpi-auto-report-api",
    "pm2:list": "pm2 list",
    "pm2:logs": "pm2 logs",
    "pm2:save": "echo 'PM2 save disabled for security'",
    "pm2:resurrect": "echo 'PM2 resurrect disabled for security'",
    "db:reset": "tsx server/scripts/reset-kpi-db.ts",
    "db:seed-users": "tsx server/scripts/seed-admin-users.ts",
    "db:seed-departments": "tsx server/scripts/seed-spo-departments.ts",
    "db:migrate:dept-master": "tsx server/scripts/migrate-to-dept-master.ts",
    "db:seed-dept-mapping": "tsx server/scripts/seed-department-mapping.ts",
    "db:migrate:measurement-id": "tsx server/scripts/migrate-metric-to-measurement-id.ts",
    "db:seed:fy25-data": "tsx server/scripts/seed-fy25-kpi-data.ts",
    "db:seed:monthly-targets": "tsx server/scripts/seed-monthly-targets.ts",
    "db:drop:metric-no": "tsx server/scripts/drop-metric-no-column.ts",
    "api-docs": "echo \"📄 API Documentation available at: http://localhost:3007/redoc\" && echo \"📃 Alternative routes: /docs, /api-docs, /swagger, /status\" && pnpm dev:frontend"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/multer": "^2.1.0",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.23",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.563.0",
    "mssql": "^10.0.4",
    "multer": "^2.1.1",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.1",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "validator": "^13.15.26",
    "vite": "^7.3.1",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/mssql": "^9.1.9",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@types/validator": "^13.15.10",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.11",
    "pm2": "^6.0.14",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
